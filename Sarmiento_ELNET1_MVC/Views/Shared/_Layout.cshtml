<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Student Information System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <nav class="sis-navbar">
        <div class="navbar-inner">
            <a class="brand" asp-controller="Student" asp-action="Index">
                <div class="brand-logo">S</div>
                <div>
                    <span class="brand-text">Student Information System</span>
                    <span class="brand-sub">Academic Records Management</span>
                </div>
            </a>
            <div class="nav-links">
                <a asp-controller="Student" asp-action="Index">Student Records</a>
            </div>
        </div>
    </nav>

    <partial name="_Header" />

    <main class="sis-main">
        @RenderBody()
    </main>

    <footer class="sis-footer">
        <div class="inner">
            <span>Student Information System &copy; @DateTime.Now.Year</span>
            <span class="ver">ASP.NET Core MVC</span>
        </div>
    </footer>

</body>
</html>
