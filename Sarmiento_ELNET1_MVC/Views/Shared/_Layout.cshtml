<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Student Information System</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🎓 Student Information System</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white"
                   asp-controller="Student"
                   asp-action="Index">📋 Students</a>

                <a class="nav-link text-white"
                   asp-controller="Student"
                   asp-action="Create">➕ Add Student</a>
            </div>
        </div>
    </nav>

    <partial name="_Header" />

    <main class="container my-4">
        @RenderBody()
    </main>

    <footer class="bg-light py-3 mt-5 border-top text-muted fixed-bottom">
        <div class="container">
            <small>Student Information System &copy; @DateTime.Now.Year | ASP.NET Core MVC</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
