@* ============================================================
   Views/Student/Index.cshtml
   ============================================================ *@

@model List<Student>

@{
    ViewData["Title"] = "Student Records";
}

<div class="page-title">Student Records</div>
<div class="page-subtitle">Manage and view all enrolled student information.</div>

@* ── SUCCESS MESSAGE ── *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-msg alert-success-msg">
        @TempData["SuccessMessage"]
    </div>
}

@* ── ERROR MESSAGE ── *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-msg alert-error-msg">
        @TempData["ErrorMessage"]
    </div>
}

@* ── ADD STUDENT FORM ── *@
<div class="sis-form-card">
    <div class="card-head">
        <h5>New Student Entry</h5>
        <span>All fields are required</span>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="post">
            <div style="display:grid; grid-template-columns: repeat(4,1fr); gap: 16px;">

                <div>
                    <label class="form-label">Student ID</label>
                    <input type="text"
                           name="Id"
                           class="form-control"
                           pattern="[0-9]*"
                           inputmode="numeric"
                           required />
                </div>

                <div>
                    <label class="form-label">Full Name</label>
                    <input type="text"
                           name="Name"
                           class="form-control"
                           required />
                </div>

                <div>
                    <label class="form-label">Course</label>
                    <select name="Course" class="form-select" required>
                        <option value="">Select Course</option>
                        <option value="BSIT">BSIT</option>
                        <option value="BSCS">BSCS</option>
                    </select>
                </div>

                <div>
                    <label class="form-label">Age</label>
                    <input type="number"
                           name="Age"
                           class="form-control"
                           placeholder="e.g. 20"
                           min="1"
                           max="99"
                           required />
                </div>

            </div>

            <div style="margin-top: 18px;">
                <button type="submit" class="btn btn-primary">Add Student</button>
            </div>
        </form>
    </div>
</div>

@* ── STUDENT CARDS ── *@
@if (Model == null || Model.Count == 0)
{
    <div class="empty-state">
        <div style="font-size:32px; margin-bottom:12px; opacity:0.3;">&#9679;</div>
        <strong style="color: #1a2744;">No records found</strong>
        <p>Use the form above to add a new student record.</p>
    </div>
}
else
{
    <div class="record-bar">
        <h5>Student Records</h5>
        <span class="count">@Model.Count record(s)</span>
    </div>

    <div class="students-grid">

        @{
            int rowNum = 1;
        }

        @foreach (var student in Model)
        {
            <div class="student-card">

                <div class="sc-header">
                    <span class="sc-name">@student.Name</span>
                    <span class="sc-num">No. @rowNum</span>
                </div>

                <div class="sc-body">
                    <div class="sc-row">
                        <span class="sc-label">Student ID</span>
                        <span class="sc-value">@student.Id</span>
                    </div>
                    <div class="sc-row">
                        <span class="sc-label">Course</span>
                        <span class="sc-value">@student.Course</span>
                    </div>
                    <div class="sc-row">
                        <span class="sc-label">Age</span>
                        <span class="sc-value">@student.Age years old</span>
                    </div>
                    <div class="sc-row">
                        <span class="sc-label">Status</span>
                        <span>
                            @if (student.Age >= 18)
                            {
                                <span class="badge badge-adult">Adult</span>
                            }
                            else
                            {
                                <span class="badge badge-minor">Minor</span>
                            }
                        </span>
                    </div>
                </div>

                <div class="sc-footer">
                    <a asp-controller="Student"
                       asp-action="Details"
                       asp-route-id="@student.Id"
                       class="btn btn-view btn-sm">View</a>

                    <a asp-controller="Student"
                       asp-action="Edit"
                       asp-route-id="@student.Id"
                       class="btn btn-edit btn-sm">Edit</a>

                    <a asp-controller="Student"
                       asp-action="Delete"
                       asp-route-id="@student.Id"
                       class="btn btn-delete btn-sm"
                       onclick="return confirm('Remove @student.Name from records?')">Delete</a>
                </div>

            </div>

            rowNum++;
        }

    </div>
}
