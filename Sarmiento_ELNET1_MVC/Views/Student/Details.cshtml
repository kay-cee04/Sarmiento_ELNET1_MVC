@model Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="page-title">Student Details</div>
<div class="page-subtitle">Viewing full record for <strong>@Model.Name</strong>.</div>

<div class="sis-detail-card">

    <div class="dc-header">
        <h4>@Model.Name</h4>
        <p>Student ID: @Model.Id</p>
    </div>

    <div class="dc-body">
        <table class="detail-table">
            <tr>
                <th>Student ID</th>
                <td>@Model.Id</td>
            </tr>
            <tr>
                <th>Full Name</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>Course</th>
                <td>@Model.Course</td>
            </tr>
            <tr>
                <th>Age</th>
                <td>@Model.Age years old</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>
                    @if (Model.Age >= 18)
                    {
                        <span class="badge badge-adult">Adult</span>
                    }
                    else
                    {
                        <span class="badge badge-minor">Minor</span>
                    }
                </td>
            </tr>
        </table>
    </div>

    <div class="dc-footer">
        <a asp-controller="Student"
           asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-edit">Edit Record</a>

        <a asp-controller="Student"
           asp-action="Index"
           class="btn btn-secondary">Back to Records</a>
    </div>

</div>
