@model Student

@{
    ViewData["Title"] = "Add Student";
}

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">➕ Add New Student</h4>
            </div>

            <div class="card-body">

                <form asp-controller="Student" asp-action="Create" method="post">

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Full Name</label>

                        <input asp-for="Name"
                               class="form-control">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Course" class="form-label fw-semibold">Course</label>

                        <select asp-for="Course" class="form-select">
                            <option value="">-- Select Course --</option>
                            <option value="BSIT">BSIT - Bachelor of Science in Information Technology</option>
                            <option value="BSCS">BSCS - Bachelor of Science in Computer Science</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Age" class="form-label fw-semibold">Age</label>
                        <input asp-for="Age"
                               class="form-control"
                               placeholder="e.g. 20" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            💾 Save Student
                        </button>

                        <a asp-controller="Student"
                           asp-action="Index"
                           class="btn btn-secondary">
                            ✖ Cancel
                        </a>
                    </div>

                </form>

            </div>
        </div>

        </div>
</div>
