@model Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="page-title">Edit Student Record</div>
<div class="page-subtitle">Update information for <strong>@Model.Name</strong>.</div>

<div class="sis-detail-card">

    <div class="dc-header">
        <h4>Edit Record</h4>
        <p>Student ID: @Model.Id</p>
    </div>

    <div class="dc-body">
        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div style="display: grid; gap: 18px;">

                <div>
                    <label asp-for="Name" class="form-label">Full Name</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div>
                    <label asp-for="Course" class="form-label">Course</label>
                    <select asp-for="Course" class="form-select">
                        <option value="">Select Course</option>
                        <option value="BSIT">BSIT</option>
                        <option value="BSCS">BSCS</option>
                    </select>
                </div>

                <div>
                    <label asp-for="Age" class="form-label">Age</label>
                    <input asp-for="Age" class="form-control" placeholder="e.g. 20" min="1" max="99" />
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 10px;">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-controller="Student"
                   asp-action="Index"
                   class="btn btn-secondary">Cancel</a>
            </div>

        </form>
    </div>

</div>
