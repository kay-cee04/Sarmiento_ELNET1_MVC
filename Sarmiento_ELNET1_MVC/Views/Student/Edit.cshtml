@model Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow border-0">

                <div class="card-header bg-warning">
                    <h4 class="mb-0">✏️ Edit Student</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Full Name</label>
                            <input asp-for="Name" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Course" class="form-label fw-semibold">Course</label>
                            <select asp-for="Course" class="form-select">
                                <option value="">-- Select Course --</option>
                                <option value="BSIT">BSIT</option>
                                <option value="BSCS">BSCS</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Age" class="form-label fw-semibold">Age</label>
                            <input asp-for="Age" class="form-control" placeholder="e.g. 20" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning px-4">
                                💾 Save Changes
                            </button>

                            <a asp-controller="Student"
                               asp-action="Index"
                               class="btn btn-secondary">
                                ✖ Cancel
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
